# ---------------------------------------------------------------------------
# OTel Learning Lab — environment variables
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.
# Never commit the real .env to git — it's in .gitignore.
# enterprise: in production these values come from a secrets manager
# (HashiCorp Vault, AWS Secrets Manager, k8s Secrets) not a flat file.
# ---------------------------------------------------------------------------

# PostgreSQL credentials
DB_NAME=otellab
DB_USER=otel
DB_PASSWORD=otelpass      # change this before exposing to any network

# Backend service URL (used by the frontend if it ever calls the API server-side)
BACKEND_URL=http://backend:8000

# ---------------------------------------------------------------------------
# Phase 2 — OTel SDK (set now, used later)
# enterprise: OTEL_* env vars are the standard way to configure the OTel SDK
# without touching application code — same pattern in Java, Go, Node, Python.
# ---------------------------------------------------------------------------
OTEL_SERVICE_NAME=otellab-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
